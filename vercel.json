{
  "redirects": [
    { "source": "/library.html", "destination": "/prompt-library.html", "permanent": true },
    { "source": "/library", "destination": "/prompt-library.html", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!.*\\.(html|png|jpg|jpeg|svg|webp|gif|ico|css|js|xml)$).*)", "destination": "/index.html" }
  ]
}
